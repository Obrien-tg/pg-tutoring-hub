{
  "name": "pg-tutoring-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p .",
    "build:css": "tailwindcss -c ./tailwind.config.js -i ./src/styles/tailwind.css -o ../backend/static/css/tailwind.css --minify",
    "watch:css": "tailwindcss -c ./tailwind.config.js -i ./src/styles/tailwind.css -o ../backend/static/css/tailwind.css --watch"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.6.0",
    "@types/socket.io": "^3.0.2",
    "tailwindcss": "^3.4.8",
    "postcss": "^8.4.24",
    "autoprefixer": "^10.4.14"
  }
}
